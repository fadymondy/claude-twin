{
  "name": "@claude-twin/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Local MCP server hosting the WebSocket bridge to the claude-twin Chrome extension",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-twin-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --build --dry",
    "test": "node --test --test-reporter=spec --enable-source-maps dist/bridge/ws-host.test.js dist/state/monitors.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}
