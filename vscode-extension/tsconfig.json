{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "types": ["node", "vscode"],
    "tsBuildInfoFile": "./out/.tsbuildinfo",
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["out", "node_modules"]
}
